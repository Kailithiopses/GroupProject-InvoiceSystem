<Window x:Class="InvoiceSystem.Search.wndSearch"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InvoiceSystem.Search"
        mc:Ignorable="d"
        Title="wndSearch" Height="450" Width="800">
    <Grid>
        <DataGrid x:Name="dgInvoiceDisplay" d:ItemsSource="{d:SampleData ItemCount=5}" Width="Auto" Height="Auto" Margin="36,199,264,35"/>


        <Label Content="Filter by ID" HorizontalAlignment="Left" Margin="86,45,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbInvoiceNumFilter" HorizontalAlignment="Left" Margin="57,92,0,0" VerticalAlignment="Top" Width="120"/>

        <Label Content="Filter by Date" HorizontalAlignment="Left" Margin="246,45,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbInvoiceDateFilter" HorizontalAlignment="Left" Margin="226,92,0,0" VerticalAlignment="Top" Width="120"/>

        <Label Content="Filter by Total Cost" HorizontalAlignment="Left" Margin="400,45,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="cbInvoiceTotalCostFilter" HorizontalAlignment="Left" Margin="400,92,0,0" VerticalAlignment="Top" Width="120"/>
        <Button x:Name="btnClearFilter" Content="Clear Filter" HorizontalAlignment="Left" Margin="667,133,0,0" VerticalAlignment="Top"/>
        <Button x:Name="btnSelectInvoice" Content="Select Invoice" HorizontalAlignment="Left" Margin="667,264,0,0" VerticalAlignment="Top"/>
        <Button x:Name="btnCancel" Content="Cancel" HorizontalAlignment="Left" Margin="667,329,0,0" VerticalAlignment="Top"/>


    </Grid>
</Window>
